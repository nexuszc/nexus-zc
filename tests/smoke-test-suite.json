{
  "version": "1.0.0",
  "timeout": 30000,
  "retryAttempts": 3,
  "retryDelay": 1000,
  "environment": {
    "baseUrl": "${NEXUS_API_URL}",
    "healthCheckInterval": 5000,
    "maxHealthCheckAttempts": 10
  },
  "testSuites": [
    {
      "name": "Health Check",
      "priority": 1,
      "tests": [
        {
          "id": "health_ping",
          "name": "API Health Ping",
          "endpoint": "/health",
          "method": "GET",
          "timeout": 5000,
          "expectedStatus": 200,
          "expectedResponse": {
            "status": "ok"
          },
          "retryAttempts": 5,
          "critical": true
        },
        {
          "id": "health_detailed",
          "name": "Detailed Health Check",
          "endpoint": "/health/detailed",
          "method": "GET",
          "timeout": 10000,
          "expectedStatus": 200,
          "expectedResponse": {
            "database": "connected",
            "cache": "operational"
          },
          "critical": true
        }
      ]
    },
    {
      "name": "Authentication",
      "priority": 2,
      "dependencies": ["health_ping"],
      "tests": [
        {
          "id": "auth_login",
          "name": "User Login",
          "endpoint": "/api/auth/login",
          "method": "POST",
          "timeout": 10000,
          "body": {
            "email": "${TEST_USER_EMAIL}",
            "password": "${TEST_USER_PASSWORD}"
          },
          "expectedStatus": 200,
          "expectedResponse": {
            "token": "{{string}}",
            "user": {
              "id": "{{string}}"
            }
          },
          "saveToken": true,
          "critical": true
        },
        {
          "id": "auth_verify",
          "name": "Token Verification",
          "endpoint": "/api/auth/verify",
          "method": "GET",
          "timeout": 5000,
          "headers": {
            "Authorization": "Bearer {{auth_login.token}}"
          },
          "expectedStatus": 200,
          "dependencies": ["auth_login"],
          "critical": true
        }
      ]
    },
    {
      "name": "Core API",
      "priority": 3,
      "dependencies": ["auth_login"],
      "tests": [
        {
          "id": "api_list_items",
          "name": "List Items",
          "endpoint": "/api/items",
          "method": "GET",
          "timeout": 10000,
          "headers": {
            "Authorization": "Bearer {{auth_login.token}}"
          },
          "expectedStatus": 200,
          "expectedResponse": {
            "items": "{{array}}",
            "total": "{{number}}"
          },
          "critical": true
        },
        {
          "id": "api_create_item",
          "name": "Create Item",
          "endpoint": "/api/items",
          "method": "POST",
          "timeout": 10000,
          "headers": {
            "Authorization": "Bearer {{auth_login.token}}",
            "Content-Type": "application/json"
          },
          "body": {
            "name": "Smoke Test Item {{timestamp}}",
            "description": "Generated by smoke test suite"
          },
          "expectedStatus": 201,
          "expectedResponse": {
            "id": "{{string}}",
            "name": "{{string}}"
          },
          "saveResponse": true,
          "critical": true
        },
        {
          "id": "api_get_item",
          "name": "Get Item by ID",
          "endpoint": "/api/items/{{api_create_item.id}}",
          "method": "GET",
          "timeout": 5000,
          "headers": {
            "Authorization": "Bearer {{auth_login.token}}"
          },
          "expectedStatus": 200,
          "dependencies": ["api_create_item"],
          "critical": true
        },
        {
          "id": "api_update_item",
          "name": "Update Item",
          "endpoint": "/api/items/{{api_create_item.id}}",
          "method": "PATCH",
          "timeout": 10000,
          "headers": {
            "Authorization": "Bearer {{auth_login.token}}",
            "Content-Type": "application/json"
          },
          "body": {
            "name": "Updated Smoke Test Item"
          },
          "expectedStatus": 200,
          "dependencies": ["api_create_item"],
          "critical": false
        },
        {
          "id": "api_delete_item",
          "name": "Delete Item",
          "endpoint": "/api/items/{{api_create_item.id}}",
          "method": "DELETE",
          "timeout": 10000,
          "headers": {
            "Authorization": "Bearer {{auth_login.token}}"
          },
          "expectedStatus": 204,
          "dependencies": ["api_create_item", "api_get_item"],
          "critical": false,
          "cleanup": true
        }
      ]
    },
    {
      "name": "Database Operations",
      "priority": 4,
      "dependencies": ["health_detailed"],
      "tests": [
        {
          "id": "db_connection",
          "name": "Database Connection Test",
          "endpoint": "/api/internal/db/ping",
          "method": "GET",
          "timeout": 5000,
          "headers": {
            "X-Internal-Key": "${INTERNAL_API_KEY}"
          },
          "expectedStatus": 200,
          "critical": true
        },
        {
          "id": "db_query",
          "name": "Database Query Test",
          "endpoint": "/api/internal/db/test-query",
          "method": "POST",
          "timeout": 10000,
          "headers": {
            "X-Internal-Key": "${INTERNAL_API_KEY}",
            "Content-Type": "application/json"
          },
          "body": {
            "query": "SELECT 1 as test"
          },
          "expectedStatus": 200,
          "expectedResponse": {
            "success": true
          },
          "critical": true
        }
      ]
    },
    {
      "name": "Cache Operations",
      "priority": 5,
      "dependencies": ["health_detailed"],
      "tests": [
        {
          "id": "cache_set",
          "name": "Cache Set Operation",
          "endpoint": "/api/internal/cache/set",
          "method": "POST",
          "timeout": 5000,
          "headers": {
            "X-Internal-Key": "${INTERNAL_API_KEY}",
            "Content-Type": "application/json"
          },
          "body": {
            "key": "smoke_test_{{timestamp}}",
            "value": "test_value",
            "ttl": 300
          },
          "expectedStatus": 200,
          "saveResponse": true,
          "critical": false
        },
        {
          "id": "cache_get",
          "name": "Cache Get Operation",
          "endpoint": "/api/internal/cache/get",
          "method": "POST",
          "timeout": 5000,
          "headers": {
            "X-Internal-Key": "${INTERNAL_API_KEY}",
            "Content-Type": "application/json"
          },
          "body": {
            "key": "{{cache_set.key}}"
          },
          "expectedStatus": 200,
          "expectedResponse": {
            "value": "test_value"
          },
          "dependencies":